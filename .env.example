# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Finnhub API Key (optional - for backup stock data)
# Get from: https://finnhub.io/
FINNHUB_API_KEY=

# CoinGecko API (optional - for crypto data)
# No API key needed for basic usage
# COINGECKO_API_KEY=

# NewsAPI.org (optional - for news/sentiment in analisa command)
# Get from: https://newsapi.org/
NEWS_API_KEY=

# === WEBHOOK SETTINGS (optional) ===
# Leave empty for polling mode (default, slower)
# Set URL to enable webhook mode (faster, recommended for production)
# Examples:
#   - Cloudflare Tunnel: https://random.trycloudflare.com
#   - Ngrok: https://abc123.ngrok.io
#   - Custom domain: https://ochobot.example.com
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8443
